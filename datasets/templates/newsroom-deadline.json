  "clueTemplates": {
    "eq": {
      "minTier": "easy",
      "variants": [
        "{a_ref} {b_phrase}.",
        "The one who {b_phrase} was {a_ref}.",
        "It was {a_ref} who {b_phrase}."
      ]
    },
    "neq": {
      "minTier": "easy",
      "variants": [
        "{a_ref} was not the one who {b_phrase}.",
        "The one who {b_phrase} was not {a_ref}.",
        "It was not {a_ref} who {b_phrase}."
      ]
    },
    "numDiff": {
      "appliesTo": "length",
      "minTier": "standard",
      "variants": [
        "{a_ref} filed {delta} more words than {b_ref}.",
        "{a_ref}'s story ran {delta} words longer than {b_ref}'s."
      ]
    },
    "threshold": {
      "appliesTo": "length",
      "minTier": "sharp",
      "variants": [
        "{a_ref} filed at least {bound} words.",
        "{a_ref} did not file fewer than {bound} words."
      ]
    },
    "oneOf": {
      "minTier": "sharp",
      "note": "disjunction: entity a is one of {x, y}",
      "variants": [
        "It was {x_label} or {y_label} for {a_ref} - not both.",
        "{a_ref} chased either {x_label} or {y_label}, and filed just one."
      ]
    },
    "oneEachOf": {
      "minTier": "sharp",
      "note": "of two entities x and y, one satisfies fact A and the other fact B",
      "variants": [
        "Of {x_ref} and {y_ref}, one {a_phrase} and the other {b_phrase}."
      ]
    },
    "ifThen": {
      "minTier": "expert",
      "note": "conditional / chained indirect reference",
      "variants": [
        "If {a_ref} {a_phrase}, then {b_ref} was not the one who {b_phrase}."
      ]
    }
  }
