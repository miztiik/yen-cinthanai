":[{"cat":"name","value":"dev"},{"cat":"price","value":"p12"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Of Cara and Dev, one displayed the poppies and the other displayed the lilies.","id":"c6","operands":[{"cat":"name","value":"cara"},{"cat":"name","value":"dev"},{"cat":"bloom","value":"poppies"},{"cat":"bloom","value":"lilies"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"Fay threw the pottery.","id":"c7","operands":[{"cat":"name","value":"fay"},{"cat":"craft","value":"pottery"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"Ben's takings came to 12 dollars more than Eli's.","id":"c8","operands":[{"cat":"name","value":"ben"},{"cat":"name","value":"eli"}],"params":{"delta":12,"dir":"greater","numericCat":"price"},"renderHint":"numDiff","type":"numDiff"},{"clueText":"Fay's takings came to 5 dollars more than Ana's.","id":"c9","operands":[{"cat":"name","value":"fay"},{"cat":"name","value":"ana"}],"params":{"delta":5,"dir":"greater","numericCat":"price"},"renderHint":"numDiff","type":"numDiff"},{"clueText":"Cara did not bring the Honey.","id":"c10","operands":[{"cat":"name","value":"cara"},{"cat":"craft","value":"honey"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Dev could not decide between the Prints and the Pottery, and set out just one.","id":"c11","operands":[{"cat":"name","value":"dev"},{"cat":"craft","value":"prints"},{"cat":"craft","value":"pottery"}],"params":{},"renderHint":"oneOf","type":"oneOf"},{"clueText":"Of Dev and Eli, one also brought the cheese and the other also brought the bread.","id":"c12","operands":[{"cat":"name","value":"dev"},{"cat":"name","value":"eli"},{"cat":"produce","value":"cheese"},{"cat":"produce","value":"bread"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"Whatever Ana brought, it was not the Apples.","id":"c13","operands":[{"cat":"name","value":"ana"},{"cat":"produce","value":"apples"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Of Cara and Fay, one displayed the poppies and the other displayed the tulips.","id":"c14","operands":[{"cat":"name","value":"cara"},{"cat":"name","value":"fay"},{"cat":"bloom","value":"poppies"},{"cat":"bloom","value":"tulips"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"the beekeeper did not bring the $10.","id":"c15","operands":[{"cat":"craft","value":"honey"},{"cat":"price","value":"p10"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"the jam-maker's table was the one that charged 20 dollars.","id":"c16","operands":[{"cat":"craft","value":"jam"},{"cat":"price","value":"p20"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"Of Dev and Ben, one also brought the cheese and the other also brought the plums.","id":"c17","operands":[{"cat":"name","value":"dev"},{"cat":"name","value":"ben"},{"cat":"produce","value":"cheese"},{"cat":"produce","value":"plums"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"The one who displayed the tulips was $15.","id":"c18","operands":[{"cat":"price","value":"p15"},{"cat":"bloom","value":"tulips"}],"params":{},"renderHint":"eq","type":"eq"}],"entities":["e0","e1","e2","e3","e4","e5"],"hintTrace":[{"forces":{"cat":"craft","entity":"e4","value":"pottery"},"fromClues":["c7","c11"]},{"forces":{"cat":"craft","entity":"e3","value":"jam"},"fromClues":["c16"]},{"forces":{"cat":"craft","entity":"e5","value":"honey"},"fromClues":["c10","c15"]},{"forces":{"cat":"craft","entity":"e1","value":"prints"},"fromClues":["c11"]},{"forces":{"cat":"craft","entity":"e0","value":"candles"},"fromClues":["c3","c4"]},{"forces":{"cat":"craft","entity":"e2","value":"soap"},"fromClues":["c1"]},{"forces":{"cat":"price","entity":"e2","value":"p10"},"fromClues":["c15"]},{"forces":{"cat":"price","entity":"e1","value":"p5"},"fromClues":["c1"]},{"forces":{"cat":"price","entity":"e5","value":"p8"},"fromClues":["c1"]},{"forces":{"cat":"price","entity":"e0","value":"p12"},"fromClues":["c5"]},{"fo