"},{"cat":"drink","value":"juice"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"$16 did not end up with the Soda.","id":"c13","operands":[{"cat":"price","value":"p16"},{"cat":"drink","value":"soda"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Of Omar and Belle, one pressed the juice and the other poured the coffee.","id":"c14","operands":[{"cat":"vendor","value":"omar"},{"cat":"vendor","value":"belle"},{"cat":"drink","value":"juice"},{"cat":"drink","value":"coffee"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"Of Rosa and Leon, one parked at pitch 6 and the other parked at pitch 2.","id":"c15","operands":[{"cat":"vendor","value":"rosa"},{"cat":"vendor","value":"leon"},{"cat":"pitch","value":"num6"},{"cat":"pitch","value":"num2"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"Of Rosa and Belle, one fired up the pizza and the other griddled the toast.","id":"c16","operands":[{"cat":"vendor","value":"rosa"},{"cat":"vendor","value":"belle"},{"cat":"dish","value":"pizza"},{"cat":"dish","value":"toast"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"the burger flipper was the one who charged 16 dollars a plate.","id":"c17","operands":[{"cat":"dish","value":"burger"},{"cat":"price","value":"p16"}],"params":{},"renderHint":"eq","type":"eq"}],"entities":["e0","e1","e2","e3","e4","e5"],"hintTrace":[{"forces":{"cat":"dish","entity":"e4","value":"sushi"},"fromClues":["c6","c11"]},{"forces":{"cat":"dish","entity":"e3","value":"burger"},"fromClues":["c17"]},{"forces":{"cat":"dish","entity":"e5","value":"toast"},"fromClues":["c10","c16"]},{"forces":{"cat":"dish","entity":"e1","value":"seafood"},"fromClues":["c11"]},{"forces":{"cat":"dish","entity":"e0","value":"pizza"},"fromClues":["c3","c16"]},{"forces":{"cat":"dish","entity":"e2","value":"fries"},"fromClues":["c1"]},{"forces":{"cat":"price","entity":"e2","value":"p9"},"fromClues":["c1"]},{"forces":{"cat":"price","entity":"e1","va