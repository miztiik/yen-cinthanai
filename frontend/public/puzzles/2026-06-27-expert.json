Then"},{"clueText":"It was not Wren who mastered levitation.","id":"c4","operands":[{"cat":"apprentice","value":"wren"},{"cat":"spell","value":"levitation"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"It was not Finn who ranked 4th.","id":"c5","operands":[{"cat":"apprentice","value":"finn"},{"cat":"rank","value":"rank4"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Of Sable and Finn, one kept the sparrow and the other kept the mouse.","id":"c6","operands":[{"cat":"apprentice","value":"sable"},{"cat":"apprentice","value":"finn"},{"cat":"familiar","value":"sparrow"},{"cat":"familiar","value":"mouse"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"Opal mastered mistcall.","id":"c7","operands":[{"cat":"apprentice","value":"opal"},{"cat":"spell","value":"mistcall"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"Bram ranked 4 places under Lux.","id":"c8","operands":[{"cat":"apprentice","value":"bram"},{"cat":"apprentice","value":"lux"}],"params":{"delta":4,"dir":"greater","numericCat":"rank"},"renderHint":"numDiff","type":"numDiff"},{"clueText":"Opal ranked 2 places under Wren.","id":"c9","operands":[{"cat":"apprentice","value":"opal"},{"cat":"apprentice","value":"wren"}],"params":{"delta":2,"dir":"greater","numericCat":"rank"},"renderHint":"numDiff","type":"numDiff"},{"clueText":"Sable was not the one who mastered starmap.","id":"c10","operands":[{"cat":"apprentice","value":"sable"},{"cat":"spell","value":"starmap"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Finn was down to Beastspeech or Mistcall, and learned just one.","id":"c11","operands":[{"cat":"apprentice","value":"finn"},{"cat":"spell","value":"beastspeech"},{"cat":"spell","value":"mistcall"}],"params":{},"renderHint":"oneOf","type":"oneOf"},{"clueText":"Of Finn and Lux, one belonged to Tidewatch and the other belonged to Emberhall.","id":"c12","operands":[{"cat":"apprentice","value":"finn"},{"cat":"apprentice","value":"lux"},{"cat":"