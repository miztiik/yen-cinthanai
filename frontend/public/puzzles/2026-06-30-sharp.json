sports"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"The one who worked the online section was 450 words.","id":"c9","operands":[{"cat":"length","value":"w450"},{"cat":"section","value":"online"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"It was Features or Copydesk for Ravi - not both.","id":"c10","operands":[{"cat":"reporter","value":"ravi"},{"cat":"section","value":"features"},{"cat":"section","value":"copydesk"}],"params":{},"renderHint":"oneOf","type":"oneOf"},{"clueText":"Dexter did not file fewer than 900 words.","id":"c11","operands":[{"cat":"reporter","value":"dexter"}],"params":{"bound":900,"dir":"atleast","numericCat":"length"},"renderHint":"threshold","type":"threshold"}],"entities":["e0","e1","e2","e3","e4"],"hintTrace":[{"forces":{"cat":"beat","entity":"e0","value":"politics"},"fromClues":["c7"]},{"forces":{"cat":"beat","entity":"e2","value":"sports"},"fromClues":["c2","c8"]},{"forces":{"cat":"beat","entity":"e3","value":"weather"},"fromClues":["c2"]},{"forces":{"cat":"beat","entity":"e1","value":"culture"},"fromClues":["c1","c5"]},{"forces":{"cat":"beat","entity":"e4","value":"crime"},"fromClues":["c5"]},{"forces":{"cat":"length","entity":"e0","value":"w450"},"fromClues":["c9"]},{"forces":{"cat":"length","entity":"e1","value":"w900"},"fromClues":["c1"]},{"forces":{"cat":"length","entity":"e2","value":"w600"},"fromClues":["c1"]},{"forces":{"cat":"length","entity":"e3","value":"w750"},"fromClues":["c1"]},{"forces":{"cat":"length","entity":"e4","value":"w1100"},"fromClues":["c1"]},{"forces":{"cat":"section","entity":"e3","value":"copydesk"},"fromClues":["c3","c10"]},{"forces":{"cat":"section","entity":"e4","value":"features"},"fromClues":["c1","c10"]},{"forces":{"cat":"section","entity":"e0","value":"online"},"fromClues":["c9"]},{"forces":{"cat":"section","entity":"e1","value":"photo"},"fromClues":["c7"]},{"forces":{"cat":"section","entity":"e2","value":"newsdesk"},"fromClues":["c4"]}],"puzzleId":"2026-06-30","scenarioId":"newsroom-deadline","schemaVersion":2,"shapeId":"grid","solution":{"e0":{"beat":"politics","length":"w450","reporter":"gail","section":"online"},"e1":{"beat":"culture","length":"w900","reporter":"dexter","section":"photo"},"e2":{"beat":"sports","length":"w600","reporter":"simone","section":"newsdesk"},"e3":{"beat":"weather","length":"w750","reporter":"hank","section":"copydesk"},"e4":{"beat":"crime","length":"w1100","reporter":"ravi","section":"features"}},"story":"It is twenty minutes to deadline and the newsroom is a wall of noise, with five reporters hammering out copy while the night editor, who has run the floor for decades, tries to work out whose story is whose before the power flicker. Each reporter has a different beat, length and section. Using the clues, match every reporter to their beat, length and section.","subjectNoun":"reporter","templateRev":1,"tier":"sharp","variant":1}
