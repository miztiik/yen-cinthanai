":"device","value":"fox"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"Round 1 was not the one who took the signet ring.","id":"c13","operands":[{"cat":"round","value":"r1"},{"cat":"prize","value":"ring"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"The one who took the gold chalice was the knight of the fox.","id":"c14","operands":[{"cat":"device","value":"fox"},{"cat":"prize","value":"chalice"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"Bram was down to Jewelled gauntlet or Silver garland, and only one was borne.","id":"c15","operands":[{"cat":"knight","value":"bram"},{"cat":"prize","value":"gauntlet"},{"cat":"prize","value":"garland"}],"params":{},"renderHint":"oneOf","type":"oneOf"},{"clueText":"Of Elspeth and Cuthbert, one hailed from Wexley and the other hailed from Greenholt.","id":"c16","operands":[{"cat":"knight","value":"elspeth"},{"cat":"knight","value":"cuthbert"},{"cat":"shire","value":"wexley"},{"cat":"shire","value":"greenholt"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"the knight of the stag was not the one who took the silver garland.","id":"c17","operands":[{"cat":"device","value":"deer"},{"cat":"prize","value":"garland"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Bram rode 3 rounds later than Rowena.","id":"c18","operands":[{"cat":"knight","value":"bram"},{"cat":"knight","value":"rowena"}],"params":{"delta":3,"dir":"greater","numericCat":"round"},"renderHint":"numDiff","type":"numDiff"},{"clueText":"Elspeth was down to Signet ring or Velvet cloak, and only one was borne.","id":"c19","operands":[{"cat":"knight","value":"elspeth"},{"cat":"prize","value":"ring"},{"cat":"prize","value":"cloak"}],"params":{},"renderHint":"oneOf","type":"oneOf"},{"clueText":"It was not the knight of the stag who rode in round 6.","id":"c20","operands":[{"cat":"device","value":"deer"},{"cat":"round","value":"r6"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Ro