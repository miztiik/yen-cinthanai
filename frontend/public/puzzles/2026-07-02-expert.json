":{"bound":10,"dir":"atleast","numericCat":"league"},"renderHint":"threshold","type":"threshold"},{"clueText":"the Palm Hollow party was not the one who traded the coconuts.","id":"c5","operands":[{"cat":"oasis","value":"palmhollow"},{"cat":"cargo","value":"coconut"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Of Omar and Amina, one led the mule and the other led the ox.","id":"c6","operands":[{"cat":"trader","value":"omar"},{"cat":"trader","value":"amina"},{"cat":"beast","value":"mule"},{"cat":"beast","value":"ox"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"The one who covered 3 leagues was Zaid.","id":"c7","operands":[{"cat":"trader","value":"zaid"},{"cat":"league","value":"l3"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"the ox driver traded the corn.","id":"c8","operands":[{"cat":"beast","value":"ox"},{"cat":"cargo","value":"corn"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"The one who covered 12 leagues was not the donkey driver.","id":"c9","operands":[{"cat":"beast","value":"donkey"},{"cat":"league","value":"l12"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Of Omar and Idris, one watered at Palm Hollow and the other watered at Cold Spring.","id":"c10","operands":[{"cat":"trader","value":"omar"},{"cat":"trader","value":"idris"},{"cat":"oasis","value":"palmhollow"},{"cat":"oasis","value":"coldspring"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"Of Idris and Layla, one traded the okra and the other traded the grapes.","id":"c11","operands":[{"cat":"trader","value":"idris"},{"cat":"trader","value":"layla"},{"cat":"cargo","value":"okra"},{"cat":"cargo","value":"grape"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"It was the Star Well party who traded the corn.","id":"c12","operands":[{"cat":"oasis","value":"starwell"},{"cat":"cargo","value":"corn"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"Layla covered 2 leagues more than Omar.","id":"c13","operands":[{"cat":"trader","value":"layla"},{"cat":"trader","value":"omar"}],"params":{"delta":2,"dir":"greater","numericCat":"league"},"renderHint":"numDiff","type":"numDiff"},{"clueText":"The one who led the camel was not Layla.","id":"c14","operands":[{"cat":"trader","value":"layla"},{"cat":"beast","value":"camel"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"The one who watered at the Red Dunes was the mare driver.","id":"c15","operands":[{"cat":"beast","value":"mare"},{"cat":"oasis","value":"reddunes"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"Farah was down to Camel or Pony, and only one was right.","id":"c16","operands":[{"cat":"trader","value":"farah"},{"cat":"beast","value":"camel"},{"cat":"beast","value":"pony"}],"params":{},"renderHint":"oneOf","type":"oneOf"},{"clueText":"It was Farah who covered 15 leagues.","id":"c17","operands":[{"cat":"trader","value":"farah"},{"cat":"league","value":"l15"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"the ox driver was not the one who covered 8 leagues.","id":"c18","operands":[{"cat":"beast","value":"ox"},{"cat":"league","value":"l8"}],"params":{},"renderHint":"neq","type":"neq"}],"entities":["e0","e1","e2","e3","e4","e5"],"hintTrace":[{"forces":{"cat":"beast","entity":"e1","value":"donkey"},"fromClues":["c9"]},{"forces":{"cat":"beast","entity":"e3","value":"pony"},"fromClues":["c16"]},{"forces":{"cat":"beast","entity":"e0","value":"mule"},"fromClues":["c6"]},{"forces":{"cat":"beast","entity":"e4","value":"mare"},"fromClues":["c1","c15"]},{"forces":{"cat":"beast","entity":"e2","value":"ox"},"fromClues":["c6","c8","c18"]},{"forces":{"cat":"beast","entity":"e5","value":"camel"},"fromClues":["c14","c16"]},{"forces":{"cat":"league","entity":"e0","value":"l10"},"fromClues":["c1"]},{"forces":{"cat":"league","entity":"e5","value":"l15"},"fromClues":["c17"]},{"forces":{"cat":"league","entity":"e2","value":"l5"},"fromClues":["c1"]},{"forces":{"cat":"league",