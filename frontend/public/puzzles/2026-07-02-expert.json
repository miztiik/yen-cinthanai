e.","id":"c3","operands":[{"cat":"zone","value":"baobab"},{"cat":"vehicle","value":"bicycle"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"Bo came back with no fewer than 7 sightings.","id":"c4","operands":[{"cat":"ranger","value":"bo"}],"params":{"bound":7,"dir":"atleast","numericCat":"sighting"},"renderHint":"threshold","type":"threshold"},{"clueText":"the one on the Acacia Flats was not the one who drove the jeep.","id":"c5","operands":[{"cat":"zone","value":"acacia"},{"cat":"vehicle","value":"jeep"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Of Bo and Kaia, one tracked the lion and the other tracked the deer.","id":"c6","operands":[{"cat":"ranger","value":"bo"},{"cat":"ranger","value":"kaia"},{"cat":"animal","value":"lion"},{"cat":"animal","value":"deer"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"The one who logged 2 sightings was Nia.","id":"c7","operands":[{"cat":"ranger","value":"nia"},{"cat":"sighting","value":"see2"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"the deer tracker rode the motorcycle.","id":"c8","operands":[{"cat":"animal","value":"deer"},{"cat":"vehicle","value":"motorcycle"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"The one who logged 9 sightings was not the giraffe tracker.","id":"c9","operands":[{"cat":"animal","value":"giraffe"},{"cat":"sighting","value":"see9"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Of Bo and Juma, one patrolled the Acacia Flats and the other patrolled the Baobab Grove.","id":"c10","operands":[{"cat":"ranger","value":"bo"},{"cat":"ranger","value":"juma"},{"cat":"zone","value":"acacia"},{"cat":"zone","value":"baobab"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"Of Juma and Petra, one rode the bicycle and the other drove the lorry.","id":"c11","operands":[{"cat":"ranger","value":"juma"},{"cat":"ranger","value":"petra"},{"cat":"vehicle","value":"bicycle"},{"cat":"vehicle","value":"lorry"}],"para