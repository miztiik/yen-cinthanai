"},{"cat":"produce","value":"bread"},{"cat":"produce","value":"apples"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"}],"entities":["e0","e1","e2","e3","e4"],"hintTrace":[{"forces":{"cat":"craft","entity":"e1","value":"honey"},"fromClues":["c7"]},{"forces":{"cat":"craft","entity":"e3","value":"jam"},"fromClues":["c1"]},{"forces":{"cat":"craft","entity":"e4","value":"prints"},"fromClues":["c1","c5"]},{"forces":{"cat":"craft","entity":"e2","value":"pottery"},"fromClues":["c8"]},{"forces":{"cat":"craft","entity":"e0","value":"soap"},"fromClues":["c1"]},{"forces":{"cat":"price","entity":"e2","value":"p20"},"fromClues":["c1"]},{"forces":{"cat":"price","entity":"e1","value":"p15"},"fromClues":["c7"]},{"forces":{"cat":"price","entity":"e4","value":"p10"},"fromClues":["c1"]},{"forces":{"cat":"price","entity":"e0","value":"p8"},"fromClues":["c1"]},{"forces":{"cat":"price","entity":"e3","value":"p5"},"fromClues":["c1"]},{"forces":{"cat":"produce","entity":"e3","value":"cheese"},"fromClues":["c1"]},{"forces":{"cat":"produce","entity":"e2","value":"apples"},"fromClues":["c2","c9"]},{"forces":{"cat":"produce","entity":"e0","value":"bread"},"fromClues":["c9"]},{"forces":{"cat":"produce","entity":"e4","value":"plums"},"fromClues":["c5","c6"]},{"forces":{"cat":"produce","entity":"e1","value":"eggs"},"fromClues":["c6"]}],"puzzleId":"2026-06-27","scenarioId":"weekend-market","schemaVersion":2,"shapeId":"grid","solution":{"e0":{"craft":"soap","name":"ben","price":"p8","produce":"bread"},"e1":{"craft":"honey","name":"ana","price":"p15","produce":"eggs"},"e2":{"craft":"pottery","name":"fay","price":"p20","produce":"apples"},"e3":{"craft":"jam","name":"cara","price":"p5","produce":"cheese"},"e4":{"craft":"prints","name":"dev","price":"p10","produce":"plums"}},"story":"Every Saturday, five friends run neighbouring stalls at the riverside craft market, watched over by old Mrs. Alvarez, who has kept the market ledger for forty years and still records every sale in green ink. This