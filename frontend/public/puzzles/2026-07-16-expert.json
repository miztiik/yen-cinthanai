:"tomasz"},{"cat":"instrument","value":"raingauge"},{"cat":"instrument","value":"sundial"}],"params":{},"renderHint":"oneOf","type":"oneOf"},{"clueText":"7 readings was not the one who stood the Night Watch.","id":"c3","operands":[{"cat":"reading","value":"reading7"},{"cat":"shift","value":"nightwatch"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Adaeze logged at least 5 readings.","id":"c4","operands":[{"cat":"observer","value":"adaeze"}],"params":{"bound":5,"dir":"atleast","numericCat":"reading"},"renderHint":"threshold","type":"threshold"},{"clueText":"It was not Kai who minded the Thermograph.","id":"c5","operands":[{"cat":"observer","value":"kai"},{"cat":"instrument","value":"thermograph"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Of Wren and Tomasz, one stood the Wind Watch and the other stood the Storm Watch.","id":"c6","operands":[{"cat":"observer","value":"wren"},{"cat":"observer","value":"tomasz"},{"cat":"shift","value":"windwatch"},{"cat":"shift","value":"stormwatch"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"It was the motorbike rider who minded the Anemometer.","id":"c7","operands":[{"cat":"ride","value":"motorcycle"},{"cat":"instrument","value":"anemometer"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"the Thermograph reader was not the one who stood the Night Watch.","id":"c8","operands":[{"cat":"instrument","value":"thermograph"},{"cat":"shift","value":"nightwatch"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"It was not the jeep rider who logged 3 readings.","id":"c9","operands":[{"cat":"ride","value":"jeep"},{"cat":"reading","value":"reading3"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"Wren was not the one who minded the Thermograph.","id":"c10","operands":[{"cat":"observer","value":"wren"},{"cat":"instrument","value":"thermograph"}],"params":{},"renderHint":"neq","type":"neq"},{"clueText":"For Kai the log read Frost Watch or Dawn Watch - just on