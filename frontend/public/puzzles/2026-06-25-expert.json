","value":"lilies"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"Of Fay and Cara, one also brought the donuts and the other also brought the cookies.","id":"c13","operands":[{"cat":"name","value":"fay"},{"cat":"name","value":"cara"},{"cat":"produce","value":"donut"},{"cat":"produce","value":"cookie"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"the painter's table was the one that also brought the cheese.","id":"c14","operands":[{"cat":"craft","value":"painting"},{"cat":"produce","value":"cheese"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"Fay's table was the one that displayed the poppies.","id":"c15","operands":[{"cat":"name","value":"fay"},{"cat":"bloom","value":"poppies"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"Fay's table was the one that threw the pottery.","id":"c16","operands":[{"cat":"name","value":"fay"},{"cat":"craft","value":"pottery"}],"params":{},"renderHint":"eq","type":"eq"},{"clueText":"Dev could not decide between the Carpentry and the Painting, and set out just one.","id":"c17","operands":[{"cat":"name","value":"dev"},{"cat":"craft","value":"carpentry"},{"cat":"craft","value":"painting"}],"params":{},"renderHint":"oneOf","type":"oneOf"}],"entities":["e0","e1","e2","e3","e4","e5"],"hintTrace":[{"forces":{"cat":"craft","entity":"e3","value":"carpentry"},"fromClues":["c17"]},{"forces":{"cat":"craft","entity":"e5","value":"candlemaking"},"fromClues":["c1"]},{"forces":{"cat":"craft","entity":"e1","value":"gardening"},"fromClues":["c2"]},{"forces":{"cat":"craft","entity":"e4","value":"soapmaking"},"fromClues":["c11"]},{"forces":{"cat":"craft","entity":"e0","value":"pottery"},"fromClues":["c11","c16"]},{"forces":{"cat":"craft","entity":"e2","value":"painting"},"fromClues":["c14","c17"]},{"forces":{"cat":"price","entity":"e5","value":"p8"},"fromClues":["c2","c9"]},{"forces":{"cat":"price","entity":"e0","value":"p5"},"fromClues":["c1"]},{"forces":{"cat":"price","entity":"e1","value":"p20"