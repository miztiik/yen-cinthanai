uice"}],"params":{},"renderHint":"oneOf","type":"oneOf"},{"clueText":"Elsa took 4 runs more than Rocco.","id":"c12","operands":[{"cat":"guest","value":"elsa"},{"cat":"guest","value":"rocco"}],"params":{"delta":4,"dir":"greater","numericCat":"run"},"renderHint":"numDiff","type":"numDiff"},{"clueText":"Nadia was down to Glacier Bowl or Fox Trail, and only one was right.","id":"c13","operands":[{"cat":"guest","value":"nadia"},{"cat":"piste","value":"glacierbowl"},{"cat":"piste","value":"foxtrail"}],"params":{},"renderHint":"oneOf","type":"oneOf"},{"clueText":"Of Mika and Nadia, one wore the green kit and the other wore the orange kit.","id":"c14","operands":[{"cat":"guest","value":"mika"},{"cat":"guest","value":"nadia"},{"cat":"kit","value":"green"},{"cat":"kit","value":"orange"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"Of Rocco and Freya, one warmed up with the coffee and the other warmed up with the warm milk.","id":"c15","operands":[{"cat":"guest","value":"rocco"},{"cat":"guest","value":"freya"},{"cat":"warmer","value":"coffee"},{"cat":"warmer","value":"milk"}],"params":{},"renderHint":"oneEachOf","type":"oneEachOf"},{"clueText":"Mika skied 8 more runs than Anders.","id":"c16","operands":[{"cat":"guest","value":"mika"},{"cat":"guest","value":"anders"}],"params":{"delta":8,"dir":"greater","numericCat":"run"},"renderHint":"numDiff","type":"numDiff"}],"entities":["e0","e1","e2","e3","e4","e5"],"hintTrace":[{"forces":{"cat":"warmer","entity":"e3","value":"milk"},"fromClues":["c6","c15"]},{"forces":{"cat":"warmer","entity":"e1","value":"juice"},"fromClues":["c5","c11"]},{"forces":{"cat":"warmer","entity":"e2","value":"tea"},"fromClues":["c1"]},{"forces":{"cat":"warmer","entity":"e4","value":"water"},"fromClues":["c10"]},{"forces":{"cat":"warmer","entity":"e0","value":"coffee"},"fromClues":["c5","c15"]},{"forces":{"cat":"warmer","entity":"e5","value":"soda"},"fromClues":["c11"]},{"forces":{"cat":"run","entity":"e1","value":"run3"},"fromClues"